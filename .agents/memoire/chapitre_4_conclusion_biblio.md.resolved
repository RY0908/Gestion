## 4.3 Script de Création de la Base de Données

La base de données est structurée en **10 tables** correspondant au MLD défini au chapitre précédent :

```sql
-- ============================================================
-- Script de création de la base de données SIGMA
-- Système d'Information de Gestion du Matériel — Sonatrach DC-ISI
-- ============================================================

-- Table EQUIPEMENT (Asset)
CREATE TABLE equipements (
    id INT PRIMARY KEY AUTO_INCREMENT,
    code_inventaire VARCHAR(20) UNIQUE NOT NULL,
    num_serie VARCHAR(50) UNIQUE,
    categorie ENUM('LAPTOP','DESKTOP','SERVER','PRINTER','PHOTOCOPIEUR','FAX',
                   'SCANNER','DESTRUCTEUR','RELIEUSE','TABLET','SMARTPHONE',
                   'MONITOR','NETWORK_DEVICE','STORAGE','PROJECTOR','PERIPHERAL',
                   'TELEPHONE','CLIMATISEUR','ONDULEUR','MOBILIER','OTHER') NOT NULL,
    marque VARCHAR(50),
    modele VARCHAR(50),
    specifications JSON,
    etat ENUM('EN_SERVICE','IN_STOCK','ASSIGNED','IN_MAINTENANCE',
              'EN_PANNE','REMPLACEMENT','RETIRED','LOST','RESERVED') DEFAULT 'IN_STOCK',
    condition_physique ENUM('NEW','GOOD','FAIR','POOR') DEFAULT 'NEW',
    date_acquisition DATE,
    prix_achat DECIMAL(15,2),
    valeur_actuelle DECIMAL(15,2),
    date_garantie DATE,
    fournisseur VARCHAR(100),
    num_facture VARCHAR(50),
    localisation VARCHAR(100),
    notes TEXT,
    date_creation DATETIME DEFAULT CURRENT_TIMESTAMP,
    date_modification DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- Table EMPLOYE (Employee)
CREATE TABLE employes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nom VARCHAR(50) NOT NULL,
    prenom VARCHAR(50) NOT NULL,
    nom_complet VARCHAR(100) AS (CONCAT(prenom, ' ', nom)) STORED,
    email VARCHAR(100) UNIQUE,
    telephone VARCHAR(20),
    matricule VARCHAR(20) UNIQUE,
    structure VARCHAR(50),
    poste_occupe VARCHAR(50),
    role ENUM('ADMIN','SUPERVISOR','TECHNICIAN','USER') DEFAULT 'USER',
    est_actif BOOLEAN DEFAULT TRUE,
    date_embauche DATE,
    id_departement INT,
    id_responsable INT,
    FOREIGN KEY (id_responsable) REFERENCES employes(id)
);

-- Table UTILISATEUR (compte système)
CREATE TABLE utilisateurs (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nom_complet VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    mot_de_passe VARCHAR(255) NOT NULL,
    role ENUM('ADMIN','SUPERVISOR','TECHNICIAN','USER') NOT NULL,
    date_creation DATETIME DEFAULT CURRENT_TIMESTAMP,
    est_actif BOOLEAN DEFAULT TRUE
);

-- Table AFFECTATION (Assignment)
CREATE TABLE affectations (
    id INT PRIMARY KEY AUTO_INCREMENT,
    id_equipement INT NOT NULL,
    id_employe INT NOT NULL,
    id_attribue_par INT NOT NULL,
    date_affectation DATE NOT NULL,
    date_retour DATE,
    motif VARCHAR(200),
    statut ENUM('ACTIVE','RETURNED','OVERDUE') DEFAULT 'ACTIVE',
    condition_retour ENUM('GOOD','DAMAGED','LOST'),
    notes_retour TEXT,
    FOREIGN KEY (id_equipement) REFERENCES equipements(id),
    FOREIGN KEY (id_employe) REFERENCES employes(id),
    FOREIGN KEY (id_attribue_par) REFERENCES employes(id)
);

-- Table MAINTENANCE (MaintenanceRecord)
CREATE TABLE maintenance (
    id INT PRIMARY KEY AUTO_INCREMENT,
    id_equipement INT NOT NULL,
    type_maintenance ENUM('PREVENTIVE','CORRECTIVE','UPGRADE','INSPECTION') NOT NULL,
    description_panne TEXT,
    date_debut DATE NOT NULL,
    date_fin DATE,
    cout_reparation DECIMAL(15,2),
    technicien VARCHAR(100),
    pieces_utilisees TEXT,
    statut ENUM('SCHEDULED','IN_PROGRESS','COMPLETED','CANCELLED') DEFAULT 'SCHEDULED',
    date_prochaine_maintenance DATE,
    FOREIGN KEY (id_equipement) REFERENCES equipements(id)
);

-- Table LICENCE (SoftwareLicense)
CREATE TABLE licences (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nom_logiciel VARCHAR(100) NOT NULL,
    editeur VARCHAR(100),
    version VARCHAR(50),
    cle_licence VARCHAR(100),
    type_licence ENUM('PERPETUAL','SUBSCRIPTION','VOLUME','OEM','OPEN_SOURCE'),
    nb_postes_autorises INT,
    nb_postes_utilises INT DEFAULT 0,
    date_acquisition DATE,
    date_expiration DATE,
    cout_annuel DECIMAL(15,2),
    statut_conformite ENUM('COMPLIANT','OVER_LICENSED','UNDER_LICENSED','EXPIRED')
);

-- Table pivot LICENCE ↔ EQUIPEMENT (N:N)
CREATE TABLE licence_equipement (
    id_licence INT NOT NULL,
    id_equipement INT NOT NULL,
    PRIMARY KEY (id_licence, id_equipement),
    FOREIGN KEY (id_licence) REFERENCES licences(id),
    FOREIGN KEY (id_equipement) REFERENCES equipements(id)
);

-- Table DEMANDE (EquipmentRequest / Ticket)
CREATE TABLE demandes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    num_demande VARCHAR(20) UNIQUE,
    id_demandeur INT NOT NULL,
    objet VARCHAR(200) NOT NULL,
    description TEXT,
    priorite ENUM('LOW','MEDIUM','HIGH','URGENT') DEFAULT 'MEDIUM',
    statut ENUM('PENDING','ASSIGNED','RESOLVED') DEFAULT 'PENDING',
    date_demande DATETIME DEFAULT CURRENT_TIMESTAMP,
    id_superviseur_assignant INT,
    id_technicien_assigne INT,
    date_resolution DATETIME,
    FOREIGN KEY (id_demandeur) REFERENCES employes(id),
    FOREIGN KEY (id_superviseur_assignant) REFERENCES employes(id),
    FOREIGN KEY (id_technicien_assigne) REFERENCES employes(id)
);

-- Table DOCUMENT (GeneratedDocument)
CREATE TABLE documents (
    id INT PRIMARY KEY AUTO_INCREMENT,
    type_document VARCHAR(30) NOT NULL,
    numero_document VARCHAR(30),
    date_generation DATETIME DEFAULT CURRENT_TIMESTAMP,
    donnees_json JSON,
    id_affectation INT,
    FOREIGN KEY (id_affectation) REFERENCES affectations(id)
);

-- Table JOURNAL_AUDIT (AuditLog)
CREATE TABLE journal_audit (
    id INT PRIMARY KEY AUTO_INCREMENT,
    type_action VARCHAR(50) NOT NULL,
    entite_type VARCHAR(30),
    entite_id VARCHAR(20),
    description TEXT,
    modifications_json JSON,
    date_action DATETIME DEFAULT CURRENT_TIMESTAMP,
    id_utilisateur INT NOT NULL,
    FOREIGN KEY (id_utilisateur) REFERENCES utilisateurs(id)
);
```

*(Voir Figure 15 : Schéma physique de la base de données)*

