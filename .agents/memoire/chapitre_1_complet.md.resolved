                     │     DC - ISI     │
                     │ (Informatique &  │
                     │ Système d'Info.) │
                     └────────┬─────────┘
                              │
          ┌───────────────────┼───────────────────┐
          │                   │                   │
  ┌───────┴────────┐  ┌──────┴───────┐   ┌───────┴─────────┐
  │   Direction    │  │  Direction   │   │   Direction     │
